# ------------------------------------------------------------------
# RAMSmith environment variables
# Copy this file to `.env` and fill in the values.
# ------------------------------------------------------------------

# --- Database -----------------------------------------------------
# Any Postgres URL. Fastest free options: Neon (neon.tech) or Supabase.
# On Vercel, add a Postgres integration and it fills this in for you.
DATABASE_URL="postgresql://user:password@host:5432/ramsmith?sslmode=require"

# --- Auth (NextAuth v5 / Auth.js) ---------------------------------
# Generate one with:  openssl rand -base64 32
AUTH_SECRET="replace-with-a-long-random-string"
# Set to your deployed URL in production, e.g. https://ramsmith.vercel.app
NEXTAUTH_URL="http://localhost:3000"

# Public base URL used for Stripe redirects. Match NEXTAUTH_URL.
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# --- Stripe -------------------------------------------------------
# From https://dashboard.stripe.com/test/apikeys (use TEST keys first).
STRIPE_SECRET_KEY="sk_test_xxx"
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_xxx"

# Webhook signing secret. When running locally with the Stripe CLI:
#   stripe listen --forward-to localhost:3000/api/stripe/webhook
# it prints a whsec_... value — paste it here.
STRIPE_WEBHOOK_SECRET="whsec_xxx"

# Price IDs for your two products (create them in the Stripe dashboard,
# each as a recurring monthly price, then paste the price_... IDs here).
# £19/mo Solo and £49/mo Team.
STRIPE_PRICE_SOLO="price_xxx_solo"
STRIPE_PRICE_TEAM="price_xxx_team"
